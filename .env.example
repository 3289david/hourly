# Polar.sh
POLAR_ACCESS_TOKEN=your_polar_access_token_here
POLAR_ORGANIZATION_ID=your_org_id_here

# Polar.sh Product IDs (from your Polar dashboard)
# Prices: $1.99 / $3.99 / $9.99 / $22.99 / $44.99
# Polar charges 5%+$0.50 per transaction — prices are set to keep healthy margins
POLAR_PRODUCT_1H=prod_xxxxxxxxxxxxxxxx
POLAR_PRODUCT_6H=prod_xxxxxxxxxxxxxxxx
POLAR_PRODUCT_24H=prod_xxxxxxxxxxxxxxxx
POLAR_PRODUCT_7D=prod_xxxxxxxxxxxxxxxx
POLAR_PRODUCT_30D=prod_xxxxxxxxxxxxxxxx

# Polar.sh Checkout URLs (from your Polar dashboard)
NEXT_PUBLIC_CHECKOUT_1H=https://buy.polar.sh/polar_cl_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_CHECKOUT_6H=https://buy.polar.sh/polar_cl_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_CHECKOUT_24H=https://buy.polar.sh/polar_cl_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_CHECKOUT_7D=https://buy.polar.sh/polar_cl_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_CHECKOUT_30D=https://buy.polar.sh/polar_cl_xxxxxxxxxxxxxxxx

# Session JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_here_at_least_32_chars

# OpenRouter API Key (for AI model routing)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Workspace storage path
WORKSPACE_ROOT=/tmp/hourly-workspaces

# App URL
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# WebSocket URL
NEXT_PUBLIC_WS_URL=wss://yourdomain.com/ws
